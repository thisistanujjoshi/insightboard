@model IEnumerable<Admin.Web.Models.Tenant>
@{
    ViewData["Title"] = "Tenants";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Tenants</h1>
    <a asp-action="Create" class="btn btn-primary">New tenant</a>
</div>

@if (TempData["Flash"] is string flash)
{
    <div class="alert alert-success">@flash</div>
}

<table class="table table-hover align-middle">
    <thead>
        <tr><th>Name</th><th>Contact</th><th>Plan</th><th>Status</th><th>Created</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Name</td>
            <td>@t.ContactEmail</td>
            <td><span class="badge text-bg-@(t.Plan == Admin.Web.Models.PlanKind.Pro ? "primary" : "secondary")">@t.Plan</span></td>
            <td><span class="badge text-bg-@(t.Status == Admin.Web.Models.TenantStatus.Active ? "success" : "warning")">@t.Status</span></td>
            <td>@t.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
            <td class="text-end">
                <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                @if (t.Status == Admin.Web.Models.TenantStatus.Active)
                {
                    <form asp-action="Suspend" asp-route-id="@t.Id" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-warning">Suspend</button>
                    </form>
                }
                else
                {
                    <form asp-action="Reactivate" asp-route-id="@t.Id" method="post" class="d-inline">
                        <button class="btn btn-sm btn-outline-success">Reactivate</button>
                    </form>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
